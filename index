      // Can be expanded later
    }

    // Initialize everything
    window.onload = function() {
      // Start floating hearts
      setInterval(createHeart, 280);
      createHeart();
      createHeart();
      createHeart();

      // Initial confetti
      setTimeout(() => {
        startCelebration();
      }, 800);

      // Auto play music hint
      console.log("%c❤️ Open the music player and enjoy your special day with her!", "color: #db2777; font-size: 16px");
    };
  </script>
